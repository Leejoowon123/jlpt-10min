yarn-debug.log*
yarn-error.log*

# ── 패키지 lock (선택) — 팀 정책상 보존하려면 이 줄을 지운다 ─
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Claude Code 로컬 설정 ────────────────────────────────────
.claude/
.aider*

# ── OS / 에디터 ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
